# ===================================================
# .env.example - 환경변수 양식 파일
# ===================================================
# 사용법:
#   1. 이 파일을 복사해서 이름을 ".env"로 바꾸세요
#   2. 각 항목의 = 오른쪽에 실제 값을 입력하세요
#   3. .env 파일은 절대 GitHub에 올리지 마세요! (API 키 유출 위험)
# ===================================================

# --- 업비트 API 키 ---
# 발급 경로: 업비트 로그인 → 마이페이지 → Open API 관리
UPBIT_ACCESS_KEY=여기에_업비트_Access_Key를_입력하세요
UPBIT_SECRET_KEY=여기에_업비트_Secret_Key를_입력하세요

# --- Supabase (데이터베이스) ---
# 발급 경로: https://supabase.com → 프로젝트 → Settings → API
SUPABASE_URL=https://여기에_프로젝트_ID.supabase.co
SUPABASE_KEY=여기에_anon_public_키를_입력하세요

# --- 텔레그램 봇 ---
# 발급 경로: 텔레그램에서 @BotFather 검색 → /newbot 명령어
TELEGRAM_BOT_TOKEN=여기에_봇_토큰을_입력하세요
# 내 채팅 ID 확인: @userinfobot 에게 /start 보내기
TELEGRAM_CHAT_ID=여기에_나의_채팅_ID를_입력하세요

# --- 매매 설정 ---
# 거래할 코인 목록 (쉼표로 구분)
TARGET_COINS=KRW-BTC,KRW-ETH,KRW-XRP
# 1회 매수 금액 (원) - 처음에는 소액으로 테스트
ORDER_AMOUNT=10000
# 변동성 돌파 전략 k값 (0.3~0.7 권장, 0.5가 기본)
VOLATILITY_K=0.5

# --- 실행 모드 ---
# true = 실제 매매, false = 시뮬레이션 (테스트용)
LIVE_TRADING=false
